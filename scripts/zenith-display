#!/usr/bin/env python3
"""zenith-display — per-client virtual display lifecycle (Zenith M3, Mutter backend).

Sunshine/Zenith app prep-command. Activates the EDID-forced virtual connector at
the exact resolution the Moonlight client asked for, and puts everything back
when the client quits the app.

Usage:
  zenith-display headless [--dry-run]   only the virtual display, real monitors off
  zenith-display dual [--dry-run]       virtual display added next to the real ones
  zenith-display restore [--dry-run]    real monitors back, virtual display off

Reads from the environment (set by Sunshine for prep-commands):
  SUNSHINE_CLIENT_WIDTH / SUNSHINE_CLIENT_HEIGHT / SUNSHINE_CLIENT_FPS

Config via env:
  ZENITH_VDD_CONNECTOR   connector name of the virtual display (default: DP-1)

Applies the config as *temporary* (never written to monitors.xml), so a crash or
reboot always falls back to the user's saved layout. The saved-layout snapshot
for restore lives in $XDG_RUNTIME_DIR/zenith-display-state.json.
"""

import datetime
import json
import os
import sys
import traceback

# Prep-commands inherit Zenith's service environment, which may lack the
# session-bus address even when the bus itself is up. Point GDBus at the
# standard user bus path explicitly so Mutter is always reachable.
if "XDG_RUNTIME_DIR" in os.environ:
    os.environ.setdefault(
        "DBUS_SESSION_BUS_ADDRESS",
        f"unix:path={os.environ['XDG_RUNTIME_DIR']}/bus",
    )

import gi

gi.require_version("Gio", "2.0")
from gi.repository import Gio, GLib  # noqa: E402

VDD = os.environ.get("ZENITH_VDD_CONNECTOR", "DP-1")
STATE_FILE = os.path.join(
    os.environ.get("XDG_RUNTIME_DIR", "/tmp"), "zenith-display-state.json"
)
# ApplyMonitorsConfig method: 1 = temporary (RAM only), 2 = persistent.
# Sessions (headless/dual) apply temporary so a crash or reboot always falls
# back to the user's saved layout. Restore applies PERSISTENT: Mutter snapshots
# monitors.xml on its own while the VDD is active, and a temporary restore
# loses to that stale snapshot on the next connector event — the real layout
# must become the durable one.
APPLY_TEMPORARY = 1
APPLY_PERSISTENT = 2


def log(msg):
    print(f"[zenith-display] {msg}", file=sys.stderr)


def dbus_proxy():
    return Gio.DBusProxy.new_for_bus_sync(
        Gio.BusType.SESSION,
        Gio.DBusProxyFlags.NONE,
        None,
        "org.gnome.Mutter.DisplayConfig",
        "/org/gnome/Mutter/DisplayConfig",
        "org.gnome.Mutter.DisplayConfig",
        None,
    )


def get_state(proxy):
    reply = proxy.call_sync("GetCurrentState", None, Gio.DBusCallFlags.NONE, -1, None)
    serial, monitors, logical, props = reply.unpack()
    return serial, monitors, logical, props


def monitor_connector(mon):
    return mon[0][0]


def monitor_modes(mon):
    """-> list of (mode_id, width, height, refresh, is_current, is_preferred)."""
    out = []
    for m in mon[1]:
        mode_id, w, h, refresh = m[0], m[1], m[2], m[3]
        flags = m[6]
        out.append(
            (
                mode_id,
                w,
                h,
                refresh,
                bool(flags.get("is-current", False)),
                bool(flags.get("is-preferred", False)),
            )
        )
    return out


def pick_mode(modes, want_w, want_h, want_fps):
    """Exact WxH with nearest fps; otherwise the largest mode that fits; else preferred."""
    exact = [m for m in modes if m[1] == want_w and m[2] == want_h]
    if exact:
        best = min(exact, key=lambda m: abs(m[3] - want_fps))
        return best, True
    fitting = [m for m in modes if m[1] <= want_w and m[2] <= want_h]
    if fitting:
        best = max(fitting, key=lambda m: (m[1] * m[2], -abs(m[3] - want_fps)))
        return best, False
    preferred = [m for m in modes if m[5]]
    return (preferred[0] if preferred else modes[0]), False


def current_mode_id(monitors, conn):
    for mon in monitors:
        if monitor_connector(mon) == conn:
            for m in monitor_modes(mon):
                if m[4]:
                    return m[0]
    return None


def current_layout(monitors, logical):
    """Snapshot of the active logical layout. One entry per *logical* monitor,
    preserving mirror groups (multiple outputs assigned to one logical monitor)."""
    snapshot = []
    for lm in logical:
        x, y, scale, transform, primary, assigned = lm[0], lm[1], lm[2], lm[3], lm[4], lm[5]
        outputs = [
            {"connector": conn, "mode_id": current_mode_id(monitors, conn)}
            for conn, _vendor, _product, _serial in assigned
        ]
        snapshot.append(
            {
                "x": x,
                "y": y,
                "scale": scale,
                "transform": transform,
                "primary": primary,
                "monitors": outputs,
            }
        )
    return snapshot


def strip_vdd(layout):
    """Drop the VDD from a layout snapshot; drop logical monitors left empty."""
    out = []
    for e in layout:
        outputs = [o for o in e["monitors"] if o["connector"] != VDD]
        if outputs:
            out.append({**e, "monitors": outputs})
    return out


def save_state_once(monitors, logical, dry_run):
    """Save the pre-VDD layout, but never overwrite an existing snapshot:
    switching headless -> dual mid-session must not clobber the real layout."""
    if os.path.exists(STATE_FILE) or dry_run:
        return
    layout = strip_vdd(current_layout(monitors, logical))
    if not layout:
        log("no non-VDD monitors active; not saving state")
        return
    with open(STATE_FILE, "w") as f:
        json.dump(layout, f)
    names = [o["connector"] for e in layout for o in e["monitors"]]
    log(f"saved layout of {names} -> {STATE_FILE}")


def build_logical(entries):
    """entries: snapshot-format dicts with a `monitors` list per logical monitor."""
    lms = []
    for e in entries:
        lms.append(
            (
                e["x"],
                e["y"],
                e["scale"],
                e["transform"],
                e["primary"],
                [(o["connector"], o["mode_id"], {}) for o in e["monitors"]],
            )
        )
    return lms


def apply(proxy, serial, logical_entries, dry_run, method=APPLY_TEMPORARY):
    lms = build_logical(logical_entries)
    if dry_run:
        log(f"dry-run; would apply (method {method}): {json.dumps(logical_entries, indent=2)}")
        return
    params = GLib.Variant("(uua(iiduba(ssa{sv}))a{sv})", (serial, method, lms, {}))
    proxy.call_sync("ApplyMonitorsConfig", params, Gio.DBusCallFlags.NONE, -1, None)
    summary = [
        (o["connector"], o["mode_id"]) for e in logical_entries for o in e["monitors"]
    ]
    log(f"applied: {summary}")


def wait_for_scanout(connector, timeout=3.0):
    """Block until the connector reports enabled scanout (plus a short settle).

    Prep-commands are synchronous: Zenith enumerates capture displays right
    after we return, and a VDD that hasn't finished its modeset yet would be
    missing from that enumeration.
    """
    import glob
    import time
    paths = glob.glob(f"/sys/class/drm/card*-{connector}/enabled")
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        for p in paths:
            try:
                if open(p).read().strip() == "enabled":
                    time.sleep(0.5)  # let the compositor commit a first frame
                    log(f"{connector} scanout is live")
                    return True
            except OSError:
                pass
        time.sleep(0.1)
    log(f"warning: {connector} did not report enabled within {timeout}s")
    return False


def client_request():
    w = int(os.environ.get("SUNSHINE_CLIENT_WIDTH", "1920"))
    h = int(os.environ.get("SUNSHINE_CLIENT_HEIGHT", "1080"))
    fps = float(os.environ.get("SUNSHINE_CLIENT_FPS", "60"))
    return w, h, fps


def main():
    if len(sys.argv) < 2 or sys.argv[1] not in ("headless", "dual", "restore"):
        print(__doc__, file=sys.stderr)
        return 2
    action = sys.argv[1]
    dry_run = "--dry-run" in sys.argv[2:]

    proxy = dbus_proxy()
    serial, monitors, logical, _props = get_state(proxy)

    vdd_mon = next((m for m in monitors if monitor_connector(m) == VDD), None)
    if action in ("headless", "dual") and vdd_mon is None:
        log(f"virtual connector {VDD} not present; is the EDID force set up on this host?")
        return 1

    if action == "restore":
        entries = []
        if os.path.exists(STATE_FILE):
            with open(STATE_FILE) as f:
                entries = json.load(f)
            if not dry_run:
                os.unlink(STATE_FILE)
        else:
            # No snapshot: bring every non-VDD monitor up at its preferred mode.
            x = 0
            for mon in monitors:
                conn = monitor_connector(mon)
                if conn == VDD:
                    continue
                mode, _ = pick_mode(monitor_modes(mon), 10**6, 10**6, 60)
                entries.append(
                    {
                        "x": x,
                        "y": 0,
                        "scale": 1.0,
                        "transform": 0,
                        "primary": x == 0,
                        "monitors": [{"connector": conn, "mode_id": mode[0]}],
                    }
                )
                x += mode[1]
        if not entries:
            log("nothing to restore to; refusing to apply an empty layout")
            return 1
        apply(proxy, serial, entries, dry_run, method=APPLY_PERSISTENT)
        return 0

    w, h, fps = client_request()
    mode, exact = pick_mode(monitor_modes(vdd_mon), w, h, fps)
    log(
        f"client wants {w}x{h}@{fps:g}; {VDD} {'exact match' if exact else 'closest mode'}: {mode[0]}"
    )

    save_state_once(monitors, logical, dry_run)

    vdd_entry = {
        "x": 0,
        "y": 0,
        "scale": 1.0,
        "transform": 0,
        "primary": True,
        "monitors": [{"connector": VDD, "mode_id": mode[0]}],
    }

    if action == "headless":
        entries = [vdd_entry]
    else:  # dual
        entries = strip_vdd(current_layout(monitors, logical))
        if not entries:
            log("no real monitors active; dual degrades to headless")
            apply(proxy, serial, [vdd_entry], dry_run)
            if not dry_run:
                wait_for_scanout(VDD)
            return 0
        right_edge = 0
        for e in entries:
            width = 0
            for o in e["monitors"]:
                for mon in monitors:
                    if monitor_connector(mon) == o["connector"]:
                        cur = [m for m in monitor_modes(mon) if m[0] == o["mode_id"]]
                        if cur:
                            width = max(width, int(cur[0][1] / e["scale"]))
            right_edge = max(right_edge, e["x"] + width)
        vdd_entry.update({"x": right_edge, "primary": False})
        entries.append(vdd_entry)
    apply(proxy, serial, entries, dry_run)
    if not dry_run:
        wait_for_scanout(VDD)
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except SystemExit:
        raise
    except Exception:
        # Zenith only records the exit code of prep-commands; keep the real
        # reason somewhere durable.
        tb = traceback.format_exc()
        print(tb, file=sys.stderr)
        try:
            logfile = os.path.join(
                os.environ.get("XDG_RUNTIME_DIR", "/tmp"), "zenith-display.log"
            )
            with open(logfile, "a") as f:
                f.write(f"--- {datetime.datetime.now().isoformat()} "
                        f"argv={sys.argv[1:]} ---\n{tb}\n")
        except OSError:
            pass
        sys.exit(1)
