#!/usr/bin/env python3
"""zenith-vdd-setup — create a virtual display connector for Zenith (M3).

Forces an unused GPU output "connected" with a generated EDID so the desktop
treats it as a real monitor. Pair it with `zenith-display` (headless/dual per
Moonlight client) for Apollo-style virtual displays on Linux.

Usage (as root):
  zenith-vdd-setup detect                     list GPUs/connectors, suggest one
  zenith-vdd-setup install [--connector DP-1] [--modes 2420x1668@60,...]
                                              generate EDID, install firmware,
                                              set kernel args; then reboot
  zenith-vdd-setup verify                     after reboot: is the VDD alive?

The EDID advertises the mode list below (edit with --modes; the first entry is
the preferred mode). Detailed timings are CVT reduced-blanking, so anything up
to ~655 MHz pixel clock encodes (4K60 yes, 4K120 no).

Kernel args are applied via GRUB (/etc/default/grub) or rpm-ostree kargs;
anything else gets the exact args printed for manual setup. The firmware blob
lands in /usr/lib/firmware/edid/zenith-vdd.bin — no initramfs changes needed:
the DRM driver loads EDID firmware from the real root at modeset time.
"""

import argparse
import os
import re
import shutil
import subprocess
import sys

FIRMWARE_DIR = "/usr/lib/firmware/edid"
BLOB_NAME = "zenith-vdd.bin"

# Default mode list. First entry = preferred. Covers common PCs, phones and
# tablets (iPad Pro 11"/13" natives, current iPhone natives, common Android).
DEFAULT_MODES = [
    (1920, 1080, 60),
    (2560, 1440, 60),
    (3840, 2160, 60),
    (1920, 1080, 120),
    (2560, 1440, 120),
    (2420, 1668, 60),  # iPad Pro 11"
    (2420, 1668, 120),
    (2752, 2064, 60),  # iPad Pro 13"
    (2796, 1290, 60),  # iPhone Pro Max
    (2556, 1179, 60),  # iPhone Pro
    (2400, 1080, 60),  # common Android
    (2560, 1600, 60),  # 16:10 laptops
    (1920, 1200, 60),
    (1280, 720, 60),
]
BASE_SLOTS = 2  # DTDs in the base block; the rest go to CTA extension blocks
EXT_SLOTS = 6  # DTDs per 128-byte CTA extension


def log(msg):
    print(f"[zenith-vdd-setup] {msg}")


def die(msg):
    print(f"[zenith-vdd-setup] ERROR: {msg}", file=sys.stderr)
    sys.exit(1)


# --------------------------------------------------------------------------
# timings
# --------------------------------------------------------------------------


def cvt_rb_native(w, h, r):
    """CVT-1.2 reduced-blanking timings, computed natively (no `cvt` binary).

    RB v1: hblank fixed at 160 px (48 front / 32 sync / 80 back); vertical
    blanking sized so the VBI lasts >= 460 us, with 3 lines front porch.
    """
    htotal = w + 160
    h_period_us = (1e6 / r - 460.0) / h
    vbi = int(460.0 / h_period_us) + 1
    vsync = 5
    if vbi < 3 + vsync + 6:
        vbi = 3 + vsync + 6
    vtotal = h + vbi
    pclk_mhz = htotal * vtotal * r / 1e6
    return dict(
        pclk10=round(pclk_mhz * 100),
        hact=w, hblank=160, hfront=48, hsync=32,
        vact=h, vblank=vbi, vfront=3, vsync=vsync,
        hpol=1, vpol=0,  # RB convention: +hsync, -vsync
    )


def cvt_rb(w, h, r):
    """Prefer the `cvt -r` binary when present (matches X's tables exactly)."""
    if shutil.which("cvt") is None:
        return cvt_rb_native(w, h, r)
    out = subprocess.check_output(["cvt", "-r", str(w), str(h), str(r)], text=True)
    line = [l for l in out.splitlines() if "Modeline" in l][0]
    toks = line.split()
    pclk = float(toks[2])
    hdisp, hss, hse, htot = map(int, toks[3:7])
    vdisp, vss, vse, vtot = map(int, toks[7:11])
    flags = " ".join(toks[11:])
    return dict(
        pclk10=round(pclk * 100),
        hact=w, hblank=htot - w,
        hfront=hss - hdisp, hsync=hse - hss,
        vact=h, vblank=vtot - h,
        vfront=vss - vdisp, vsync=vse - vss,
        hpol=1 if "+hsync" in flags else 0,
        vpol=1 if "+vsync" in flags else 0,
    )


# --------------------------------------------------------------------------
# EDID construction (ported from the proven make_edid.py)
# --------------------------------------------------------------------------


def dtd(m, hmm=600, vmm=340):
    pc = m["pclk10"]
    if pc > 0xFFFF:
        die(f"{m['hact']}x{m['vact']}: pixel clock {pc / 100:.2f} MHz exceeds the "
            "655.35 MHz DTD limit — drop this mode or lower its refresh rate")
    b = bytearray(18)
    b[0] = pc & 0xFF
    b[1] = (pc >> 8) & 0xFF
    b[2] = m["hact"] & 0xFF
    b[3] = m["hblank"] & 0xFF
    b[4] = ((m["hact"] >> 8) & 0xF) << 4 | ((m["hblank"] >> 8) & 0xF)
    b[5] = m["vact"] & 0xFF
    b[6] = m["vblank"] & 0xFF
    b[7] = ((m["vact"] >> 8) & 0xF) << 4 | ((m["vblank"] >> 8) & 0xF)
    b[8] = m["hfront"] & 0xFF
    b[9] = m["hsync"] & 0xFF
    b[10] = ((m["vfront"] & 0xF) << 4) | (m["vsync"] & 0xF)
    b[11] = (((m["hfront"] >> 8) & 0x3) << 6 | ((m["hsync"] >> 8) & 0x3) << 4
             | ((m["vfront"] >> 4) & 0x3) << 2 | ((m["vsync"] >> 4) & 0x3))
    b[12] = hmm & 0xFF
    b[13] = vmm & 0xFF
    b[14] = ((hmm >> 8) & 0xF) << 4 | ((vmm >> 8) & 0xF)
    flags = 0x18  # digital, separate sync
    if m["vpol"]:
        flags |= 0x04
    if m["hpol"]:
        flags |= 0x02
    b[17] = flags
    return bytes(b)


def range_limits_desc():
    return bytes([0, 0, 0, 0xFD, 0, 23, 165, 15, 255, 66,
                  0x0A, 0x20, 0x20, 0x20, 0x20, 0x20, 0x20, 0x20])


def name_desc(name="ZenithVDD"):
    body = (name + "\n").encode()[:13].ljust(13, b" ")
    return bytes([0, 0, 0, 0xFC, 0]) + body


def checksum(block):
    return (256 - (sum(block) % 256)) % 256


def base_block(modes, n_extensions):
    b = bytearray(128)
    b[0:8] = bytes([0, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0xFF, 0])
    b[8:10] = bytes([0x31, 0xD8])  # PNP id "LNX"
    b[10:12] = bytes([0x02, 0x00])
    b[16] = 0
    b[17] = 36  # model year 2026
    b[18] = 1
    b[19] = 4  # EDID 1.4
    b[20] = 0xA5  # digital input, 8bpc, DisplayPort
    b[21] = 60
    b[22] = 34  # size cm
    b[23] = 120  # gamma 2.2
    b[24] = 0x02  # preferred timing = DTD1
    b[25:35] = bytes([0xEE, 0x91, 0xA3, 0x54, 0x4C, 0x99, 0x26, 0x0F, 0x50, 0x54])
    for i in range(38, 54):
        b[i] = 0x01
    descs = [dtd(cvt_rb(*m)) for m in modes[:BASE_SLOTS]]
    descs += [range_limits_desc(), name_desc()]
    off = 54
    for d in descs:
        b[off:off + 18] = d
        off += 18
    b[126] = n_extensions
    b[127] = checksum(b[0:127])
    return bytes(b)


def cta_ext(modes):
    b = bytearray(128)
    b[0] = 0x02
    b[1] = 0x03  # CTA-861 rev 3
    b[2] = 4  # DTDs start right after the header (no data blocks)
    off = 4
    for mode in modes:
        b[off:off + 18] = dtd(cvt_rb(*mode))
        off += 18
    b[127] = checksum(b[0:127])
    return bytes(b)


def build_edid(modes):
    ext_modes = modes[BASE_SLOTS:]
    ext_blocks = [ext_modes[i:i + EXT_SLOTS] for i in range(0, len(ext_modes), EXT_SLOTS)]
    edid = base_block(modes, len(ext_blocks))
    for blk in ext_blocks:
        edid += cta_ext(blk)
    assert sum(edid[0:128]) % 256 == 0
    for i in range(1, len(edid) // 128):
        assert sum(edid[128 * i:128 * (i + 1)]) % 256 == 0
    return edid


# --------------------------------------------------------------------------
# system inspection / kernel args
# --------------------------------------------------------------------------


def connectors():
    out = []
    for path in sorted(os.listdir("/sys/class/drm")):
        m = re.match(r"(card\d+)-(.+)", path)
        if not m:
            continue
        card, conn = m.group(1), m.group(2)
        with open(f"/sys/class/drm/{path}/status") as f:
            status = f.read().strip()
        with open(f"/sys/class/drm/{path}/enabled") as f:
            enabled = f.read().strip()
        driver = os.path.basename(
            os.path.realpath(f"/sys/class/drm/{card}/device/driver")
        )
        out.append(dict(card=card, connector=conn, status=status,
                        enabled=enabled, driver=driver))
    return out


def suggest():
    """Pick a disconnected connector on a real GPU: DP first, never eDP/LVDS,
    skip virtual/bochs devices."""
    virtual_drivers = {"bochs-drm", "bochs", "virtio_gpu", "vkms", "cirrus", "qxl"}
    cands = [c for c in connectors()
             if c["status"] == "disconnected"
             and c["driver"] not in virtual_drivers
             and not c["connector"].startswith(("eDP", "LVDS", "Writeback"))]
    cands.sort(key=lambda c: (not c["connector"].startswith("DP"), c["connector"]))
    return cands[0] if cands else None


def kernel_args(conn, driver):
    args = [f"drm.edid_firmware={conn}:edid/{BLOB_NAME}", f"video={conn}:e"]
    if driver == "nvidia":
        args.insert(0, "nvidia-drm.modeset=1")
    return args


def current_cmdline():
    with open("/proc/cmdline") as f:
        return f.read().split()


def apply_kargs(args):
    missing = [a for a in args if a not in current_cmdline()]
    if not missing:
        log("kernel args already present")
        return True
    if shutil.which("rpm-ostree") and os.path.isdir("/ostree"):
        subprocess.check_call(["rpm-ostree", "kargs"]
                              + [f"--append={a}" for a in missing])
        log(f"rpm-ostree kargs appended: {' '.join(missing)}")
        return True
    grub = "/etc/default/grub"
    if os.path.exists(grub):
        with open(grub) as f:
            text = f.read()
        m = re.search(r'^(GRUB_CMDLINE_LINUX_DEFAULT=")([^"]*)(")', text, re.M)
        if not m:
            m = re.search(r'^(GRUB_CMDLINE_LINUX=")([^"]*)(")', text, re.M)
        if m:
            line = m.group(2)
            for a in missing:
                if a not in line.split():
                    line += " " + a
            text = text[:m.start()] + m.group(1) + line.strip() + m.group(3) + text[m.end():]
            with open(grub, "w") as f:
                f.write(text)
            updater = shutil.which("update-grub") or shutil.which("grub2-mkconfig")
            if updater and "update-grub" in updater:
                subprocess.check_call([updater])
            elif updater:
                subprocess.check_call([updater, "-o", "/boot/grub2/grub.cfg"])
            log(f"GRUB cmdline appended: {' '.join(missing)}")
            return True
    log("could not manage the bootloader automatically.")
    log("add these kernel args yourself, then reboot:")
    log("  " + " ".join(args))
    return False


# --------------------------------------------------------------------------
# commands
# --------------------------------------------------------------------------


def cmd_detect(_):
    for c in connectors():
        mark = ""
        print(f"  {c['card']}/{c['connector']:<12} {c['status']:<12} "
              f"enabled={c['enabled']:<3} driver={c['driver']}{mark}")
    s = suggest()
    if s:
        print(f"\nsuggested VDD connector: {s['connector']} "
              f"({s['card']}, {s['driver']})")
    else:
        print("\nno free connector found — all outputs are in use or virtual")
    return 0


def parse_modes(spec):
    modes = []
    for part in spec.split(","):
        m = re.match(r"(\d+)x(\d+)@(\d+)$", part.strip())
        if not m:
            die(f"bad mode '{part}' (want WxH@R, e.g. 2420x1668@60)")
        modes.append(tuple(int(g) for g in m.groups()))
    return modes


def cmd_install(args):
    if os.geteuid() != 0:
        die("install must run as root")
    conn = args.connector
    driver = None
    for c in connectors():
        if c["connector"] == conn:
            driver = c["driver"]
            if c["status"] == "connected":
                die(f"{conn} has a real display connected — pick another "
                    "connector (see `zenith-vdd-setup detect`)")
    if driver is None:
        s = suggest()
        if not s:
            die("no free connector; pass --connector explicitly")
        conn, driver = s["connector"], s["driver"]
        log(f"auto-selected connector {conn} ({driver})")

    modes = parse_modes(args.modes) if args.modes else DEFAULT_MODES
    edid = build_edid(modes)
    extra_args = []
    fw_dir = FIRMWARE_DIR
    try:
        os.makedirs(fw_dir, exist_ok=True)
        with open(os.path.join(fw_dir, ".zenith-write-test"), "w") as f:
            f.write("")
        os.unlink(os.path.join(fw_dir, ".zenith-write-test"))
    except OSError:
        # Immutable /usr (Silverblue/ostree): stage firmware in /etc and point
        # the kernel's firmware loader there first (it still falls back to
        # /lib/firmware for everything else).
        fw_dir = "/etc/firmware/edid"
        os.makedirs(fw_dir, exist_ok=True)
        extra_args.append("firmware_class.path=/etc/firmware")
        log(f"/usr/lib/firmware is read-only; using {fw_dir} + firmware_class.path")
    path = os.path.join(fw_dir, BLOB_NAME)
    with open(path, "wb") as f:
        f.write(edid)
    log(f"wrote {path} ({len(edid)} bytes, {len(modes)} modes, "
        f"preferred {modes[0][0]}x{modes[0][1]}@{modes[0][2]})")

    apply_kargs(kernel_args(conn, driver) + extra_args)
    log("REBOOT to activate the virtual display, then run: zenith-vdd-setup verify")
    return 0


def cmd_verify(_):
    cl = current_cmdline()
    fw = [a for a in cl if a.startswith("drm.edid_firmware=")]
    if not fw:
        log("no drm.edid_firmware= in the running kernel cmdline — did you reboot?")
        return 1
    conn = fw[0].split("=", 1)[1].split(":", 1)[0]
    for c in connectors():
        if c["connector"] == conn:
            ok = c["status"] == "connected"
            log(f"{conn}: status={c['status']} enabled={c['enabled']} "
                f"driver={c['driver']}")
            if ok:
                log("virtual display is live — wire it into Zenith apps with "
                    "zenith-display (headless/dual)")
            return 0 if ok else 1
    log(f"connector {conn} not found in /sys/class/drm")
    return 1


def main():
    ap = argparse.ArgumentParser(description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = ap.add_subparsers(dest="cmd", required=True)
    sub.add_parser("detect")
    ins = sub.add_parser("install")
    ins.add_argument("--connector")
    ins.add_argument("--modes", help="comma-separated WxH@R list; first = preferred")
    sub.add_parser("verify")
    args = ap.parse_args()
    return {"detect": cmd_detect, "install": cmd_install, "verify": cmd_verify}[args.cmd](args)


if __name__ == "__main__":
    sys.exit(main())
