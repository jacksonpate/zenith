{
  "env": {
    "PATH": "$(PATH):$(HOME)/.local/bin"
  },
  "apps": [
    {
      "name": "Desktop",
      "image-path": "desktop.png"
    },
    {
      "name": "Headless",
      "image-path": "desktop.png",
      "prep-cmd": [
        {
          "do": "zenith-display headless",
          "undo": "zenith-display restore",
          "elevated": "false"
        }
      ]
    },
    {
      "name": "Extend",
      "image-path": "desktop.png",
      "prep-cmd": [
        {
          "do": "zenith-display dual",
          "undo": "zenith-display restore",
          "elevated": "false"
        }
      ]
    }
  ]
}
