{
  "env": {
    "PATH": "$(PATH):$(HOME)/.local/bin"
  },
  "apps": [
    {
      "name": "Desktop",
      "image-path": "desktop.png"
    },
    {
      "name": "Headless",
      "image-path": "desktop.png",
      "prep-cmd": [
        {
          "do": "zenith-display headless",
          "undo": "zenith-display restore",
          "elevated": "false"
        }
      ]
    },
    {
      "name": "Dual Display",
      "image-path": "desktop.png",
      "prep-cmd": [
        {
          "do": "zenith-display dual",
          "undo": "zenith-display restore",
          "elevated": "false"
        }
      ]
    },
    {
      "name": "Steam Big Picture",
      "detached": [
        "setsid steam steam://open/bigpicture"
      ],
      "prep-cmd": [
        {
          "do": "",
          "undo": "setsid steam steam://close/bigpicture"
        }
      ],
      "image-path": "steam.png"
    }
  ]
}
